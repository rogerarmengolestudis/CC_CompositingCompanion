set cut_paste_input [stack 0]
version 15.2 v6
push $cut_paste_input
Gizmo {
 name FB_QC4
 knobChanged "\n \nthis_node = nuke.thisNode()\nthis_knob = nuke.thisKnob()\n \nif this_node.knob('select').value() == \"Difference\":\n    this_node.knob('DiffGain').setVisible(True)\n    this_node.knob('GrainGain').setVisible(False)\n    this_node.knob('BlacksExp').setVisible(False)\n    this_node.knob('WhitesGain').setVisible(False)\n    this_node.knob('Sat').setVisible(False)\n    this_node.knob('Dissolve').setVisible(False)\n    this_node.knob('Channels').setVisible(False)\n    this_node.knob('PixelError').setVisible(False)\n    this_node.knob('PixelErrorOverlay').setVisible(False)\nelif this_node.knob('select').value() == \"Grain\":\n    this_node.knob('DiffGain').setVisible(False)\n    this_node.knob('GrainGain').setVisible(True)\n    this_node.knob('BlacksExp').setVisible(False)\n    this_node.knob('WhitesGain').setVisible(False)\n    this_node.knob('Sat').setVisible(False)\n    this_node.knob('Dissolve').setVisible(False)\n    this_node.knob('Channels').setVisible(False)\n    this_node.knob('PixelError').setVisible(False)\n    this_node.knob('PixelErrorOverlay').setVisible(False)\nelif this_node.knob('select').value() == \"Blacks\":\n    this_node.knob('DiffGain').setVisible(False)\n    this_node.knob('GrainGain').setVisible(False)\n    this_node.knob('BlacksExp').setVisible(True)\n    this_node.knob('WhitesGain').setVisible(False)\n    this_node.knob('Sat').setVisible(False)\n    this_node.knob('Dissolve').setVisible(False)\n    this_node.knob('Channels').setVisible(False)\n    this_node.knob('ChannelsText').setVisible(False)\n    this_node.knob('PixelErrorOverlay').setVisible(False)\nelif this_node.knob('select').value() == \"Whites\":\n    this_node.knob('DiffGain').setVisible(False)\n    this_node.knob('GrainGain').setVisible(False)\n    this_node.knob('BlacksExp').setVisible(False)\n    this_node.knob('WhitesGain').setVisible(True)\n    this_node.knob('Sat').setVisible(False)\n    this_node.knob('Dissolve').setVisible(False)\n    this_node.knob('Channels').setVisible(False)\n    this_node.knob('PixelError').setVisible(False)\n    this_node.knob('PixelErrorOverlay').setVisible(False)\nelif this_node.knob('select').value() == \"Color\":\n    this_node.knob('DiffGain').setVisible(False)\n    this_node.knob('GrainGain').setVisible(False)\n    this_node.knob('BlacksExp').setVisible(False)\n    this_node.knob('WhitesGain').setVisible(False)\n    this_node.knob('Sat').setVisible(True)\n    this_node.knob('Dissolve').setVisible(False)\n    this_node.knob('Channels').setVisible(False)\n    this_node.knob('PixelError').setVisible(False)\n    this_node.knob('PixelErrorOverlay').setVisible(False)\nelif this_node.knob('select').value() == \"Channels\":\n    this_node.knob('DiffGain').setVisible(False)\n    this_node.knob('GrainGain').setVisible(False)\n    this_node.knob('BlacksExp').setVisible(False)\n    this_node.knob('WhitesGain').setVisible(False)\n    this_node.knob('Sat').setVisible(False)\n    this_node.knob('Dissolve').setVisible(False)\n    this_node.knob('Channels').setVisible(True)\n    this_node.knob('PixelError').setVisible(False)\n    this_node.knob('PixelErrorOverlay').setVisible(False)\nelif this_node.knob('select').value() == \"Dissolve\":\n    this_node.knob('DiffGain').setVisible(False)\n    this_node.knob('GrainGain').setVisible(False)\n    this_node.knob('BlacksExp').setVisible(False)\n    this_node.knob('WhitesGain').setVisible(False)\n    this_node.knob('Sat').setVisible(False)\n    this_node.knob('Dissolve').setVisible(True)\n    this_node.knob('Channels').setVisible(False)\n    this_node.knob('PixelError').setVisible(False)\n    this_node.knob('PixelErrorOverlay').setVisible(False)\nelif this_node.knob('select').value() == \"Pixel Error\":\n    this_node.knob('DiffGain').setVisible(False)\n    this_node.knob('GrainGain').setVisible(False)\n    this_node.knob('BlacksExp').setVisible(False)\n    this_node.knob('WhitesGain').setVisible(False)\n    this_node.knob('Sat').setVisible(False)\n    this_node.knob('Dissolve').setVisible(False)\n    this_node.knob('Channels').setVisible(False)\n    this_node.knob('PixelError').setVisible(True)\n    this_node.knob('PixelErrorText').setVisible(True)\n    \nif this_node.knob('borders').value() == \"Default\":\n    this_node.knob('bkgcolor').setVisible(False)\n    this_node.knob('borderSize').setVisible(False)\nelif this_node.knob('borders').value() == \"Full\":\n    this_node.knob('bkgcolor').setVisible(True)\n    this_node.knob('borderSize').setVisible(True)\nelif this_node.knob('borders').value() == \"Top Right\":\n    this_node.knob('bkgcolor').setVisible(True) \n    this_node.knob('borderSize').setVisible(True)   \nelif this_node.knob('borders').value() == \"Top Left\":\n    this_node.knob('bkgcolor').setVisible(True)  \n    this_node.knob('borderSize').setVisible(True)  \nelif this_node.knob('borders').value() == \"Bottom Right\":\n    this_node.knob('bkgcolor').setVisible(True)  \n    this_node.knob('borderSize').setVisible(True)  \nelif this_node.knob('borders').value() == \"Bottom Left\":\n    this_node.knob('bkgcolor').setVisible(True)  \n    this_node.knob('borderSize').setVisible(True)  \n  \n"
 tile_color 0x6a55ffff
 label "\[value select]\n"
 note_font "Verdana Bold"
 note_font_size 12
 selected true
 xpos 25941
 ypos 8868
 addUserKnob {20 mode l QC}
 addUserKnob {26 MODE l "" t "\n<b>Difference</b> – Check if the comp is safe and shows no difference from the plate.\n\n<b>Grain</b> – Check grain consistency between the comp and the plate.\n\n<b>Blacks</b> – Check the black point levels of your comp.\n\n<b>Whites</b> – Check the white point levels of your comp.\n\n<b>Color</b> – Compare the saturation of your comp to the plate.\n\n<b>Channels</b> – Inspect different channels to check consistency with the plate.\n\n<b>Pixel Error</b> – Displays an RGB warning map if any negative, NaN, or infinite pixel values are present in your comp.\n\n<b>Dissolve</b> – A Dissolve knob between comp and plate, useful for checking tracks and other issues." +STARTLINE T "<p style=\"color: orange; font-weight: bold;\">MODE</p>"}
 addUserKnob {4 select l " " t "\n<b>Difference</b> – Check if the comp is safe and shows no difference from the plate.\n\n<b>Grain</b> – Check grain consistency between the comp and the plate.\n\n<b>Blacks</b> – Check the black point levels of your comp.\n\n<b>Whites</b> – Check the white point levels of your comp.\n\n<b>Color</b> – Compare the saturation of your comp to the plate.\n\n<b>Channels</b> – Inspect different channels to check consistency with the plate.\n\n<b>Pixel Error</b> – Displays an RGB warning map if any negative, NaN, or infinite pixel values are present in your comp.\n\n<b>Dissolve</b> – A Dissolve knob between comp and plate, useful for checking tracks and other issues." M {Difference Grain Blacks Whites Color Channels "Pixel Error" Dissolve "" ""}}
 addUserKnob {32 Compare l "<p style=\"color: yellow; font-weight: bold;\">Compare</p>" -STARTLINE T "# Get the Switch node (change \"Switch1\" to the actual name of your node)\nset switchNode \[node Switch2]\n\n# Get the current value of the \"which\" knob\nset currentValue \[value \$switchNode.which]\n\n# Toggle the value (if 0, set to 1; if 1, set to 0)\nif \{\$currentValue == 0\} \{\n    set newValue 1\n\} else \{\n    set newValue 0\n\}\n\n# Set the new value to the \"which\" knob\nknob \$switchNode.which \$newValue"}
 addUserKnob {6 sbs l "Side by Side" -STARTLINE}
 addUserKnob {26 space4 l "" +STARTLINE T " "}
 addUserKnob {26 SETTINGS l "" t "\n<b>Note:</b> Each mode has its own specific settings. \nAdjust parameters accordingly — they may vary depending on the plate and comp HSVL levels, or just select the channels to inspect" +STARTLINE T "<p style=\"color: orange; font-weight: bold;\">SETTINGS</p>"}
 addUserKnob {7 DiffGain l Gain R 0 4}
 DiffGain 1
 addUserKnob {7 GrainGain l Gain +HIDDEN R 0 4}
 GrainGain 4
 addUserKnob {7 BlacksExp l Exposure +HIDDEN R 0.5 1}
 BlacksExp 1
 addUserKnob {7 WhitesGain l Gain +HIDDEN R 0 4}
 WhitesGain 1
 addUserKnob {7 Sat l Saturation +HIDDEN R 0 4}
 Sat 4
 addUserKnob {4 Channels l "Channel Select" +HIDDEN M {Red Green BLUE Alpha Hue SATURATION LUMINANCE "" ""}}
 Channels BLUE
 addUserKnob {4 PixelError l "Mode Select" t "Check NEG, NAN, INF pixels" +HIDDEN M {ALL Neg NaN Inf "" "" "" "" ""}}
 addUserKnob {6 PixelErrorOverlay l "Overlay RGB Values" -STARTLINE +HIDDEN}
 addUserKnob {7 Dissolve +HIDDEN}
 addUserKnob {26 space_1 l "" +STARTLINE T "  "}
 addUserKnob {26 ""}
 addUserKnob {26 space5 l "" +STARTLINE T "  "}
 addUserKnob {26 BOUNDARIES l "" t "\nUse this to check for artifacts or edge lines (errors) at the frame boundaries.\n\n" +STARTLINE T "<p style=\"color: orange; font-weight: bold;\">BOUNDARIES</p>"}
 addUserKnob {26 space2 l "" +STARTLINE T " "}
 addUserKnob {4 borders l "Check Boundaries" M {Default Full "Top Left" "Top Right" "Bottom Left" "Bottom Righ" "" ""}}
 addUserKnob {18 bkgcolor l "Border Color" +HIDDEN}
 bkgcolor {1 0 0}
 addUserKnob {6 bkgcolor_panelDropped l "panel dropped state" -STARTLINE +HIDDEN}
 addUserKnob {7 borderSize l "Border Size" +HIDDEN R 1 100}
 borderSize 80
 addUserKnob {26 space l "" +STARTLINE T " "}
 addUserKnob {26 ""}
 addUserKnob {26 sign l "" +STARTLINE T "<p style=\"align: center; color: cyan; font-weight: bold; font-style: italic;\">@by Felix Bueno</p>"}
}
