Group {
 name mtComa
 tile_color 0xe0834cff
 note_font "Verdana Bold"
 addUserKnob {20 User}
 addUserKnob {6 checkDis l "check Distortion" +STARTLINE}
 addUserKnob {26 text_1 l " " T " "}
 addUserKnob {7 lenght l Iterations t "The amount of iterations" R 1 10}
 lenght 10
 addUserKnob {7 offset l Lenght t "How far the tail extends" R -0.4 0.4}
 offset 0.25
 addUserKnob {26 ""}
 addUserKnob {7 growth l "Expo Growth" t "The exponential amount of blur" R 0 6}
 growth 3
 addUserKnob {7 linearGrowth l "Linear Growth" t "The linear amount of blur" R 0 10}
 linearGrowth 1
 addUserKnob {26 ""}
 addUserKnob {7 core l Core t "Inner Mix" R 0 2}
 core 0.45
 addUserKnob {7 coreexpansion l "Core expansion" R 0.01 5}
 coreexpansion 1.5
 addUserKnob {26 text l " " T " "}
 addUserKnob {20 group l "Advance Options" n 1}
 group 0
 addUserKnob {7 decay l Decay}
 decay 0.5
 addUserKnob {26 text_7 l " " T " "}
 addUserKnob {41 size l "Noise Size" T Noise1.size}
 addUserKnob {41 size_1 l "Noise Blur" T Blur73.size}
 addUserKnob {7 noisePower l Noise}
 addUserKnob {26 text_6 l " " T " "}
 addUserKnob {7 rScale l "Red Lenght" R -0.5 0.5}
 addUserKnob {7 gScale l "Green Lenght" R -0.5 0.5}
 addUserKnob {7 bScale l "Blue Lenght" R -0.5 0.5}
 addUserKnob {26 text_3 l " " T " "}
 addUserKnob {7 rBlur l "Red Growth"}
 addUserKnob {7 gBlur l "Green Growth"}
 addUserKnob {7 bBlur l "Blue Growth"}
 addUserKnob {20 endGroup n -1}
 addUserKnob {26 text_2 l " " T " "}
 addUserKnob {7 intensity l Intensity t MIX R 0 2}
 intensity 1
 addUserKnob {26 text_4 l " " T " "}
 addUserKnob {26 text_5 l " " T "Miguel Torija - Coma beta"}
 addUserKnob {6 color_rgb_panelDropped l "panel dropped state" +HIDDEN +STARTLINE}
}
