Group {
 name mtAnam_ChAstigmatism
 inputs 2
 tile_color 0xff4c2dff
 label "\[value astType]"
 note_font "Verdana Bold"
 note_font_size 12
 addUserKnob {20 User}
 addUserKnob {41 useGPUIfAvailable l "Use GPU if available" T BlinkScript1.useGPUIfAvailable}
 addUserKnob {26 ""}
 addUserKnob {4 astType l type M {tangential sagittal "" ""}}
 astType sagittal
 addUserKnob {4 qualityAst l quality t "You will need to push the quality leves if you have high distortion values, with low distortion levels, mid quality should be ok" -STARTLINE M {"very low" low mid high "very high" ultra "" "" ""}}
 qualityAst high
 addUserKnob {6 checkDis l "check distortion" -STARTLINE}
 addUserKnob {26 text l " " T " "}
 addUserKnob {14 tanSize l "Tangential Size" R 0 100}
 tanSize 12
 addUserKnob {7 sagSize l "Sagittal Size" t Sa}
 sagSize 0.25
 addUserKnob {26 text_3 l "  " T "   "}
 addUserKnob {14 redSlide t "This does not replace chromaAB, its just to enfatize subtle astigmatism effects on the different channels" R 0 100}
 redSlide 1
 addUserKnob {14 greenSlide t "This does not replace chromaAB, its just to enfatize subtle astigmatism effects on the different channels" R 0 100}
 addUserKnob {14 blueSlide t "This does not replace chromaAB, its just to enfatize subtle astigmatism effects on the different channels" R 0 100}
 addUserKnob {26 ""}
 addUserKnob {7 mixanam l mix}
 mixanam 1
 addUserKnob {26 text_2 l "    " T "   "}
 addUserKnob {26 text_1 l "     " T "Miguel Torija - Anamorphic Astigmatism Chroma Beta"}
}
