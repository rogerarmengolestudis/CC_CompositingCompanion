  kernelSource "kernel Astigmatism : ImageComputationKernel<ePixelWise>\n\{\n  Image<eRead, eAccessRandom, eEdgeClamped> src; // the input image\n  Image<eRead, eAccessPoint, eEdgeClamped> STMapStandard; \n  Image<eRead, eAccessPoint, eEdgeClamped> STMapTangential; \n  Image<eRead, eAccessPoint, eEdgeClamped> STMapSagittalpos;\n  Image<eRead, eAccessPoint, eEdgeClamped> STMapSagittalneg;\n  Image<eWrite> dst; // the output image\n\n  param:\n// This parameter is made available to the user.\n    int count;\n    bool Tangential;\n    bool Sagittal;\n\n\n  local:\n// This local variable is not exposed to the user.\n    float2 UVTangential;\n    float2 UVSagittalPos;\n    float2 UVSagittalNeg;\n    float2 UVSagittal;\n    int2 resolution;\n    float4 outputTangential;\n    float4 outputSagittalpos;\n    float4 outputSagittalneg;\n    float4 outputSagittal;  \n    float4 output;  \n  // In define(), parameters can be given labels and default values.\n  void define() \{\n\n  \}\n\n  // The init() function is run before any calls to process().\n  // Local variables can be initialized here.\n  void init() \{\n    // Initialise coefficients according to rec. 709 standard.\n    resolution.x = src.bounds.width();\n    resolution.y = src.bounds.height();\t    \n  \}\n\n  void process(int2 pos) \{\n    if(Tangential == 1)\{\n      for(int i = 0; i < count; i++) \{\n\n        UVTangential.x = (STMapStandard().x+(STMapTangential().x-STMapStandard().x)*(float(i)/count))*resolution.x-.5f;\n        UVTangential.y = (STMapStandard().y+(STMapTangential().y-STMapStandard().y)*(float(i)/count))*resolution.y-.5f;\n\n        outputTangential += bilinear(src, UVTangential.x, UVTangential.y);\n\n      \}\n    outputTangential = outputTangential/(count+1);\n    output =  outputTangential;\n    \}\t\n\n    if(Tangential == 0)\{\n      UVTangential.x = STMapStandard().x*resolution.x-.5f;\n      UVTangential.y = STMapStandard().y*resolution.y-.5f;\n\n      outputTangential = bilinear(src, UVTang