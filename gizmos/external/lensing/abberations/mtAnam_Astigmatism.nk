Group {
 name mtAnam_Astigmatism
 inputs 2
 tile_color 0xff7d3cff
 label "\[value astType]"
 note_font "Verdana Bold"
 note_font_size 12
 addUserKnob {20 User}
 addUserKnob {41 useGPUIfAvailable l "Use GPU if available" T BlinkScript1.useGPUIfAvailable}
 addUserKnob {41 vectorize l "Vectorize on CPU" -STARTLINE T BlinkScript1.vectorize}
 addUserKnob {26 ""}
 addUserKnob {4 astType l type M {tangential sagittal "" ""}}
 addUserKnob {4 qualityAst l quality t "You will need to push the quality leves if you have high distortion values, with low distortion levels, mid quality should be ok" M {"very low" low mid high "very high" ultra "" "" ""}}
 qualityAst high
 addUserKnob {6 checkDis l "check distortion" -STARTLINE}
 addUserKnob {26 text l " " T " "}
 addUserKnob {14 tanSize l "Tangential Size" R 0 100}
 tanSize 12
 addUserKnob {7 sagSize l "Sagittal Size" t Sa}
 sagSize 0.25
 addUserKnob {26 ""}
 addUserKnob {7 mixanam l mix}
 mixanam 1
 addUserKnob {26 text_2 l "    " T "   "}
 addUserKnob {26 text_1 l "     " T "Miguel Torija - Anamorphic Astigmatism Beta"}
}
