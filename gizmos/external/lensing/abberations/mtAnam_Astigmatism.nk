 BlinkScript {
  inputs 5
  recompileCount 53
  ProgramGroup 1
  KernelDescription "2 \"Astigmatism\" iterate pixelWise 7ada9b0260075949ef3e76e4caab2de68d70893b11fd8620d1b757247d0d95e7 6 \"src\" Read Random \"STMapStandard\" Read Point \"STMapTangential\" Read Point \"STMapSagittalpos\" Read Point \"STMapSagittalneg\" Read Point \"dst\" Write Point 3 \"count\" Int 1 AAAAAA== \"Tangential\" Bool 1 AA== \"Sagittal\" Bool 1 AA== 3 \"count\" 1 1 \"Tangential\" 1 1 \"Sagittal\" 1 1 10 \"UVTangential\" Float 2 1 AAAAAAAAAAA= \"UVSagittalPos\" Float 2 1 AAAAAAAAAAA= \"UVSagittalNeg\" Float 2 1 AAAAAAAAAAA= \"UVSagittal\" Float 2 1 AAAAAAAAAAA= \"resolution\" Int 2 1 AAAAAAAAAAA= \"outputTangential\" Float 4 1 AAAAAAAAAAAAAAAAAAAAAA== \"outputSagittalpos\" Float 4 1 AAAAAAAAAAAAAAAAAAAAAA== \"outputSagittalneg\" Float 4 1 AAAAAAAAAAAAAAAAAAAAAA== \"outputSagittal\" Float 4 1 AAAAAAAAAAAAAAAAAAAAAA== \"output\" Float 4 1 AAAAAAAAAAAAAAAAAAAAAA=="
  kernelSource "kernel Astigmatism : ImageComputationKernel<ePixelWise>\n\{\n  Image<eRead, eAccessRandom, eEdgeClamped> src; // the input image\n  Image<eRead, eAccessPoint, eEdgeClamped> STMapStandard; \n  Image<eRead, eAccessPoint, eEdgeClamped> STMapTangential; \n  Image<eRead, eAccessPoint, eEdgeClamped> STMapSagittalpos;\n  Image<eRead, eAccessPoint, eEdgeClamped> STMapSagittalneg;\n  Image<eWrite> dst; // the output image\n\n  param:\n// This parameter is made available to the user.\n    int count;\n    bool Tangential;\n    bool Sagittal;\n\n\n  local:\n// This local variable is not exposed to the user.\n    float2 UVTangential;\n    float2 UVSagittalPos;\n    float2 UVSagittalNeg;\n    float2 UVSagittal;\n    int2 resolution;\n    float4 outputTangential;\n    float4 outputSagittalpos;\n    float4 outputSagittalneg;\n    float4 outputSagittal;  \n    float4 output;  \n  // In define(), parameters can be given labels and default values.\n  void define() \{\n\n  \}\n\n  // The init() function is run before any calls to process().\n  // Local variables can be initialized here.\n  void init() \{\n    // Initialise coefficients according to rec. 709 standard.\n    resolution.x = src.bounds.width();\n    resolution.y = src.bounds.height();\t    \n  \}\n\n  void process(int2 pos) \{\n    if(Tangential == 1)\{\n      for(int i = 0; i < count; i++) \{\n\n        UVTangential.x = (STMapStandard().x+(STMapTangential().x-STMapStandard().x)*(float(i)/count))*resolution.x-.5f;\n        UVTangential.y = (STMapStandard().y+(STMapTangential().y-STMapStandard().y)*(float(i)/count))*resolution.y-.5f;\n\n        outputTangential += bilinear(src, UVTangential.x, UVTangential.y);\n\n      \}\n    outputTangential = outputTangential/(count+1);\n    output =  outputTangential;\n    \}\t\n\n    if(Tangential == 0)\{\n      UVTangential.x = STMapStandard().x*resolution.x-.5f;\n      UVTangential.y = STMapStandard().y*resolution.y-.5f;\n\n      outputTangential = bilinear(src, UVTangential.x, UVTangential.y);   \n      output =  outputTangential;\n    \}\n  // Sagittal Affter\n    if(Sagittal == 1)\{\n      for(int i = 0; i < count; i++) \{\n\n        UVSagittalPos.x = (STMapStandard().x+(STMapSagittalpos().x-STMapStandard().x)*(float(i)/count))*resolution.x-.5f;\n        UVSagittalPos.y = (STMapStandard().y+(STMapSagittalpos().y-STMapStandard().y)*(float(i)/count))*resolution.y-.5f;\n\n        outputSagittalpos += bilinear(src, UVSagittalPos.x, UVSagittalPos.y);\n\n      \}\n    outputSagittalpos = outputSagittalpos/(count+1);\n\n      for(int i = 0; i < count; i++) \{\n\n        UVSagittalNeg.x = (STMapStandard().x+(STMapSagittalneg().x-STMapStandard().x)*(float(i)/count))*resolution.x-.5f;\n        UVSagittalNeg.y = (STMapStandard().y+(STMapSagittalneg().y-STMapStandard().y)*(float(i)/count))*resolution.y-.5f;\n\n        outputSagittalneg += bilinear(src, UVSagittalNeg.x, UVSagittalNeg.y);\n\n      \}\n    outputSagittalneg = outputSagittalneg/(count+1);\n    outputSagittal = (outputSagittalpos+outputSagittalneg)/2;\n    output =  outputSagittal;\n    \}\t\n\n    \t\n    dst()= output;\n\n\n  \}\n\};\n"
  useGPUIfAvailable false
  vectorize false
  rebuild ""
  Astigmatism_count {{QualityCounter.integer}}
  Astigmatism_Tangential {{astType==0?1:0}}
  Astigmatism_Sagittal {{astType==1?1:0}}
  rebuild_finalise ""
  name BlinkScript1
  xpos -94
  ypos 1554
 }
